# =============================================================================
# AcousticSpace — Backend Environment Variable Template
#
# Copy this file to .env before running the backend:
#   cp .env.example .env          # macOS / Linux
#   copy .env.example .env        # Windows
#
# The .env file is gitignored and must never be committed.  [NFR-5.4]
# All variables below have safe defaults for local development.
# Override them in docker-compose.yml for the Docker environment.  [DEPL-7]
# =============================================================================

# Application environment label.
# Allowed values: development | production
APP_ENV=development

# Absolute or relative path to the trained AST checkpoint file.
# The backend auto-detects this file at startup:
#   - File present  → ast-transformer inference mode  [FR-11.10]
#   - File absent   → heuristic fallback mode          [FR-4.1]
MODEL_CHECKPOINT_PATH=../ml/checkpoints/ast_deepfake.pt

# Maximum permitted audio upload size in megabytes.
# Requests exceeding this limit are rejected with HTTP 413.  [FR-1.3]
MAX_UPLOAD_SIZE_MB=25

# Target sample rate (Hz) for all audio resampling.
# Must match the sample rate the model was trained on.  [FR-2.3, DR-3]
SAMPLE_RATE=16000

# PyTorch compute device.
# Allowed values: cpu | cuda
# The full stack runs correctly on cpu — GPU is optional.  [NFR-2.2]
DEVICE=cpu

# Comma-separated list of origins that are permitted to call the API.
# Wildcard (*) must never be used here.  [NFR-5.3]
# Add http://localhost:80 when running via Docker Compose.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Authentication  [AUTH]
# =============================================================================

# Secret key used to sign and verify JWTs (HS256).
# Generate a strong value with:  openssl rand -hex 32
# This MUST be overridden in production — the placeholder below is unsafe.
JWT_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32

# Lifetime of the short-lived access token in minutes.
# Default: 30 minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Lifetime of the standard refresh token in days.
# Default: 7 days.
REFRESH_TOKEN_EXPIRE_DAYS=7

# Lifetime of the "remember me" refresh token in days.
# Default: 30 days.
REFRESH_TOKEN_REMEMBER_DAYS=30

# SQLAlchemy database URL for the auth user store.
# Default: SQLite file at backend/auth.db (development only).
# For production use a PostgreSQL DSN, e.g.:
#   DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/acousticspace
DATABASE_URL=sqlite:///./auth.db

# =============================================================================
# Security  [SEC]
# =============================================================================

# JWT issuer claim — must match JWT_ISSUER in the backend.
# Tokens from a different issuer are rejected.
JWT_ISSUER=acousticspace-api

# JWT audience claim — must match JWT_AUDIENCE in the backend.
JWT_AUDIENCE=acousticspace-client

# Path to the append-only audit log file (JSON Lines format).
# Rotated daily; 30 days of history retained.
AUDIT_LOG_PATH=audit.log

# slowapi rate-limit storage backend.
# Default: in-memory (suitable for single-process development).
# For multi-process / multi-instance deployments use Redis:
#   RATE_LIMIT_STORAGE=redis://localhost:6379/0
RATE_LIMIT_STORAGE=memory://

# =============================================================================
# Monitoring  [MON]
# =============================================================================

# Logging level for all application loggers.
# Allowed values: DEBUG | INFO | WARNING | ERROR | CRITICAL
# In production, INFO is recommended. DEBUG is very verbose.
LOG_LEVEL=INFO

# Path where the metrics exposition file is written on shutdown (optional).
# Leave empty to disable file-based metrics persistence.
# METRICS_EXPORT_PATH=metrics_snapshot.json

# Disk-space warning threshold in megabytes.
# The /health/detailed endpoint emits "degraded" when free disk < this value.
DISK_WARN_MB=500

# Disk-space critical threshold in megabytes.
# The /health/detailed endpoint emits "critical" when free disk < this value.
DISK_CRITICAL_MB=100
